# Dépendances
node_modules/
.venv/
__pycache__/
*.pyc
*.egg-info/

# Build
dist/
build/
# Cache incrémental de tsc : change à chaque compilation, ne dit rien du code
*.tsbuildinfo

# Caches d'outils (régénérés à chaque exécution — jamais versionnés)
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Secrets / env (jamais commités)
infra/env/.env
*.env
!*.env.example
# Script de provisionnement DB natif : contient le mot de passe applicatif
infra/local/provisionner-db.sql

# Données / uploads locaux
/data/

# OS / IDE
.DS_Store
Thumbs.db
.idea/

# Certificats / cles TLS (vivent seulement sur le serveur — jamais versionnes)
cert/
*.pem
*.key
*.pfx
*.crt
# Sauvegardes de base (pg_dump)
*.dump

# Sources de conception confidentielles (banque) — jamais publiees
docs/_sources-conception/
infra/nginx/certs/
