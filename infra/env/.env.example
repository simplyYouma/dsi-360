# DSI 360 — variables d'environnement (exemple). Copier en infra/env/.env (jamais commité).

# PostgreSQL
POSTGRES_USER=dsi360
POSTGRES_PASSWORD=changez-moi
POSTGRES_DB=dsi360

# API
DSI360_ENVIRONNEMENT=dev
DSI360_DATABASE_URL=postgresql+asyncpg://dsi360:changez-moi@postgres:5432/dsi360
DSI360_REDIS_URL=redis://redis:6379/0
DSI360_AUTH_MODE=local
DSI360_JWT_SECRET_KEY=remplacez-par-un-secret-fort

# Authentification Microsoft Entra ID / OIDC (à renseigner le moment venu)
# DSI360_OIDC_TENANT_ID=
# DSI360_OIDC_CLIENT_ID=
# DSI360_OIDC_CLIENT_SECRET=
