# Modèle de configuration native DSI 360 — copier en infra/local/.env puis renseigner.
# Le fichier .env réel contient des secrets et n'est JAMAIS commité (cf. .gitignore).

DSI360_ENVIRONNEMENT=dev

# Base : rôle applicatif dédié (cf. infra/local/provisionner-db.sql). Adapter le mot de passe.
DSI360_DATABASE_URL=postgresql+asyncpg://dsi360:MOT_DE_PASSE_FORT@localhost:5432/dsi360

# Authentification locale : chaque agent définit son mot de passe via le lien reçu par e-mail
# à la création de son compte (ADR-0004). Pas d'annuaire AD/LDAP/M365.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
DSI360_JWT_SECRET_KEY=CHANGER_SECRET_JWT

# Compte administrateur initial (à changer à la 1re connexion)
DSI360_SEED_ADMIN_EMAIL=admin@afgbank.ml
DSI360_SEED_ADMIN_PASSWORD=CHANGER_MOT_DE_PASSE_ADMIN

# URL publique de l'app (liens e-mail). En dev : serveur Vite.
DSI360_URL_APP=http://localhost:5290

# --- E-mails automatiques (affectations, mentions, échéances/dépassements SLA, escalades) ---
# Coupés par défaut (dev/démo : notifications internes seules). EN PRODUCTION : passer à true une
# fois le relais SMTP renseigné ci-dessous. Les e-mails de compte (activation, réinitialisation)
# ne dépendent PAS de ce drapeau.
DSI360_NOTIF_EMAIL_ACTIVE=false

# --- SMTP (laisser SMTP_HOTE vide simule les envois : rien n'est réellement expédié) ---
SMTP_HOTE=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_UTILISATEUR=
SMTP_MOT_DE_PASSE=
SMTP_TLS=true
SMTP_EXPEDITEUR=
